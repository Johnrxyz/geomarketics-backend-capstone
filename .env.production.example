# PythonAnywhere Production Environment Variables
# Copy this file to .env on your PythonAnywhere server and update the values.

# 1. SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=generate-a-strong-random-secret-key-here-for-production

# 2. SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# 3. Replace 'yourusername' with your actual PythonAnywhere username
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# 4. Replace with your actual Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-vercel-project-url.vercel.app

# Database configuration (Defaults to SQLite which is fine for prototype/light usage)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

GEMINI_API_KEY="your_api_key_here"